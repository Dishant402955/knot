NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=


NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

DATABASE_URL=

# Public origin for share links (watch URLs returned to desktop)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backblaze B2 (S3-compatible) — required for upload + watch playback
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005

# Bucket CORS must allow PUT from Electron origin knot://app (and GET for playback).
# Example allowed origins: knot://app, http://localhost:3000

B2_MASTER_KEY_ID=
B2_MASTER_APPLICATION_KEY=
