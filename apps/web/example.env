# ─────────────────────────────────────────────────────────────────────────────
# Knot Web — environment template
# ─────────────────────────────────────────────────────────────────────────────
#
# Setup:
#   1. Copy this file to apps/web/.env (or .env.local)
#   2. Fill in Clerk, DATABASE_URL, and Backblaze B2 values
#   3. Run: pnpm --filter web db:migrate
#   4. Run: pnpm --filter web dev
#
# Production checklist: docs/b2-production.md
# Validate production env: pnpm --filter web assert:production
# Escape hatch for local prod smoke: KNOT_ALLOW_LOCAL_PRODUCTION=1
#
# Never commit real secrets. Prefer bucket-scoped B2 application keys in prod.
# ─────────────────────────────────────────────────────────────────────────────

# ── Clerk (https://dashboard.clerk.com) ──────────────────────────────────────
# Application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Auth route paths (must match app/(auth) routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Enable usernames in Clerk if you want @mention autocomplete to resolve.

# ── Database (Neon / Postgres) ───────────────────────────────────────────────
# Drizzle uses this for migrate / studio / runtime queries.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── Public app origin ────────────────────────────────────────────────────────
# Used for share links (/r/{slug}, /watch/{id}) and embed snippets.
# Local:  http://localhost:3000
# Prod:   https://your-domain.com  (must be https for assert:production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional alias read by some helpers / desktop alignment docs
# KNOT_WEB_APP_URL=http://localhost:3000

# ── Backblaze B2 (S3-compatible) — required for upload + watch playback ──────
# Create a bucket + application key with read/write on that bucket.
# Endpoint / region must match your bucket’s region (B2 S3-compatible API).
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005

# Optional: master key for one-off bucket admin only — DO NOT deploy to hosts
# B2_MASTER_KEY_ID=
# B2_MASTER_APPLICATION_KEY=

# Uploads are API → B2 (desktop never talks to B2). Configure bucket CORS for
# signed GET playback from your web origin and knot://app — see docs/b2-production.md.

# ── Page Agent (in-page UI help) ─────────────────────────────────────────────
# Optional OpenAI-compatible LLM. When unset, Knot Guide mode uses heuristics.
# The key stays on the server — the browser calls /api/page-agent/v1/* only.
# PAGE_AGENT_API_KEY=
# Or: OPENAI_API_KEY=
# PAGE_AGENT_BASE_URL=https://api.openai.com/v1
# PAGE_AGENT_MODEL=gpt-4o-mini
# Examples: DashScope compatible-mode, OpenAI, DeepSeek, local Ollama OpenAI shim.
