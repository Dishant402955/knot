# Clerk — same values as apps/web/.env (Next.js)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Next.js web app (API + dashboard)
KNOT_WEB_APP_URL=http://localhost:3000

# Optional: override Frontend API host if auto-derived host is wrong
# (Dashboard → API keys → Frontend API, e.g. fitting-trout-62.clerk.accounts.dev)
# VITE_CLERK_FAPI_HOST=

# ── Desktop Clerk / OAuth (required for Google & GitHub) ─────────────────────
# In Clerk Dashboard:
# 1. Native applications → enable Native API
# 2. Allowed redirect URL (exact, with trailing slash):
#      knot://app/
# 3. Social connections → enable Google and GitHub (same as web)
#
# The desktop app loads the UI over knot://app (not http://localhost).
# That is required by @clerk/electron so Clerk does not reject requests with
# "Origin and Authorization headers conflict" (HTTP 400).
#
# Recording: each session writes independently playable chunk-NNNN.webm files
# (~5s). Tray indicator must be ready before the center countdown starts;
# capture prepares during countdown so encoding starts ASAP at 0.
