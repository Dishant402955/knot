# Clerk — same values as apps/web/.env (Next.js)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Next.js web app (API + dashboard)
KNOT_WEB_APP_URL=http://localhost:3000

# ── Google / GitHub OAuth (desktop) ─────────────────────────────────────────
# In Clerk Dashboard:
# 1. Native applications → enable Native API
# 2. Allowed redirect URL (exact):
#      knot://app/
# 3. Social connections → enable Google and GitHub (same as web)
# 4. Google/GitHub provider apps can keep Clerk's hosted callback;
#    Clerk then redirects into Knot via knot://app/
